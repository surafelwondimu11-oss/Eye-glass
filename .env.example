# Core server settings
PORT=5000
JWT_SECRET=your_jwt_secret_here

# MySQL settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DATABASE=pharmacy

# Required only when creating admin accounts from the public registration form
ADMIN_REGISTRATION_KEY=replace_with_a_private_admin_key

# Required only when creating pharmacist accounts from the public registration form
PHARMACIST_REGISTRATION_KEY=replace_with_a_private_pharmacist_key

# Payment destination config (shown in Checkout UI)
PAYMENT_CBE_RECEIVER=Sura Pharmacy PLC
PAYMENT_CBE_DESTINATION_TYPE=CBE Merchant Account
PAYMENT_CBE_DESTINATION_VALUE=1000284459123
PAYMENT_CBE_INSTRUCTION=Transfer the exact total amount to this CBE account and enter the transaction reference below.

PAYMENT_TELEBIRR_RECEIVER=Sura Pharmacy PLC
PAYMENT_TELEBIRR_DESTINATION_TYPE=telebirr Merchant Number
PAYMENT_TELEBIRR_DESTINATION_VALUE=0911223344
PAYMENT_TELEBIRR_INSTRUCTION=Send the total amount to this telebirr number and provide the payment reference.

PAYMENT_AWASH_RECEIVER=Sura Pharmacy PLC
PAYMENT_AWASH_DESTINATION_TYPE=Awash Account Number
PAYMENT_AWASH_DESTINATION_VALUE=7001122334455
PAYMENT_AWASH_INSTRUCTION=Complete transfer to this Awash account, then submit your reference number.

PAYMENT_BOA_RECEIVER=Sura Pharmacy PLC
PAYMENT_BOA_DESTINATION_TYPE=BOA Account Number
PAYMENT_BOA_DESTINATION_VALUE=0100456789123
PAYMENT_BOA_INSTRUCTION=Transfer payment to this BOA account and provide the exact transaction reference.

# Telebirr real-gateway-ready mode
# false = simulated immediate completion
# true  = initiated payment + webhook/verify completion flow
TELEBIRR_LIVE_MODE=false

# Telebirr checkout/deeplink URL used when live mode is enabled
# Example: https://payments.telebirr.et/checkout
TELEBIRR_CHECKOUT_URL=

# Secret expected from telebirr webhook header (x-webhook-secret or x-telebirr-signature)
TELEBIRR_WEBHOOK_SECRET=

# Chapa gateway configuration
# Set TELEBIRR_LIVE_MODE independently from Chapa
CHAPA_SECRET_KEY=
CHAPA_BASE_URL=https://api.chapa.co/v1
CHAPA_CURRENCY=ETB

# Where Chapa redirects customer after payment
CHAPA_RETURN_URL=http://localhost:5174/payment-result

# Public backend endpoint Chapa can call (use your deployed HTTPS domain in production)
CHAPA_CALLBACK_URL=http://localhost:5000/api/v1/payments/webhook/chapa

# Optional extra webhook secret check used by this app (x-webhook-secret / x-chapa-signature)
CHAPA_WEBHOOK_SECRET=
